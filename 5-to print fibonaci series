//5-to print fibonaci series
import java.util.Scanner;
public class main{
public static void main(String[] args){
    Scanner sc= new Scanner(System.in);
    System.out.print("enter the number : ");
    int num = sc.nextInt();
    int a=0;
    int b=1;
    for(int i=0;i<num;i++){
        System.out.print(a+" ");
        int c= a+b;
        a=b;
        b=c;
    }
}
}
